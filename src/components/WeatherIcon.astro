---
interface Props {
  /** Condition slug produced by the weather mapper (e.g. "cloud-rain"). */
  icon?: string;
  class?: string;
}

const { icon = "", class: className = "w-4 h-4" } = Astro.props;

const KNOWN = [
  "sun",
  "cloud-sun",
  "cloud",
  "cloud-rain",
  "cloud-lightning",
  "cloud-snow",
  "cloud-fog",
];
// Unknown conditions fall back to a neutral cloud.
const resolved = KNOWN.includes(icon) ? icon : "cloud";
---

{
  resolved === "sun" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <circle cx="12" cy="12" r="4" stroke-width="2" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke-width="2" stroke-linecap="round" />
    </svg>
  )
}
{
  resolved === "cloud-sun" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2v2M4.93 4.93l1.41 1.41M2 12h2" stroke-width="2" stroke-linecap="round" />
      <circle cx="12" cy="10" r="3" stroke-width="2" />
      <path d="M6.5 19a4.5 4.5 0 01-.42-8.98 6.002 6.002 0 0111.84 0A4.5 4.5 0 0117.5 19H6.5z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  resolved === "cloud" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6.5 19a4.5 4.5 0 01-.42-8.98 6.002 6.002 0 0111.84 0A4.5 4.5 0 0117.5 19H6.5z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  resolved === "cloud-rain" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 16.2A5 5 0 0018 7h-1.26A8 8 0 104 15.25M8 19v2M12 19v3M16 19v2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  resolved === "cloud-lightning" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 16.2A5 5 0 0018 7h-1.26A8 8 0 104 15.25" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M12.5 18l-2 3h2.5l-2 3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  resolved === "cloud-snow" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 16.2A5 5 0 0018 7h-1.26A8 8 0 104 15.25" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M8 18.5h.01M12 18.5h.01M16 18.5h.01M10 21.5h.01M14 21.5h.01" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
{
  resolved === "cloud-fog" && (
    <svg class={className} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M19 16.2A5 5 0 0018 7h-1.26A8 8 0 104 15.25" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <path d="M6 19h12M7 22h10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )
}
