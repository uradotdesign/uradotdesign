---
import type { TocHeading } from "../../lib/toc";

interface Props {
  headings: TocHeading[];
  label: string;
  /** Hide below this many headings (a 1-2 item TOC is just noise). */
  minHeadings?: number;
}

const { headings, label, minHeadings = 3 } = Astro.props;
const show = headings.length >= minHeadings;
---

{
  show && (
    <nav
      aria-label={label}
      class="toc not-prose mb-16 border-l border-[var(--color-border)] pl-5"
    >
      <p class="text-xs font-semibold uppercase tracking-wider opacity-60 mb-4">
        {label}
      </p>
      <ol class="space-y-2 text-sm leading-snug">
        {headings.map((h) => (
          <li class={h.level === 3 ? "pl-4" : ""}>
            <a
              href={`#${h.id}`}
              class="inline-block opacity-70 hover:opacity-100 hover:underline decoration-1 underline-offset-4 transition-opacity"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
