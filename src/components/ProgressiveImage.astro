---
import {
  getAssetThumbUrl,
  getOptimizedAssetUrl,
  buildAssetSrcSet,
  DEFAULT_IMAGE_WIDTHS,
} from '../lib/directus';

interface ImageSource {
  media: string;
  srcset: string;
}

interface Props {
  src?: string | null;
  lqip?: string | null;
  placeholder?: 'blur' | 'fade' | 'none';
  fill?: boolean;
  alt?: string;
  class?: string;
  imgClass?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  width?: number;
  height?: number;
  sizes?: string;
  sources?: ImageSource[];
  widths?: readonly number[];
  quality?: number;
  optimize?: boolean;
  objectPosition?: string | null;
}

const {
  src = null,
  lqip = null,
  placeholder = 'blur',
  fill = false,
  alt = '',
  class: className = '',
  imgClass = '',
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  width,
  height,
  sizes,
  sources = [],
  widths = DEFAULT_IMAGE_WIDTHS,
  quality = 80,
  optimize = true,
  objectPosition = null,
} = Astro.props;

// Serve capped, modern-format derivatives instead of raw originals. Directus
// generates + caches each width on demand. SVGs are returned unchanged.
const useOptimized = optimize && Boolean(src);
const fallbackWidth = Math.min(1600, Math.max(...widths));
const displaySrc = useOptimized
  ? getOptimizedAssetUrl(src, { width: fallbackWidth, quality })
  : src;
const srcset = useOptimized ? buildAssetSrcSet(src, widths, { quality }) : null;
const resolvedSizes = sizes ?? (useOptimized ? '100vw' : undefined);
const resolvedSources = useOptimized
  ? sources.map((s) => ({
      media: s.media,
      srcset: buildAssetSrcSet(s.srcset, widths, { quality }) ?? s.srcset,
    }))
  : sources;

// Auto-derive the LQIP from the source when one isn't supplied, so every
// image gets blur-up by default. A blur tier with no resolvable LQIP (e.g.
// no src) degrades to a plain fade.
const resolvedLqip =
  lqip ?? (placeholder === 'blur' ? getAssetThumbUrl(src) : null);
const tier = placeholder === 'blur' && !resolvedLqip ? 'fade' : placeholder;
const isProgressive = tier !== 'none';

const wrapperClass = [
  isProgressive ? 'ura-prog' : null,
  isProgressive && fill ? 'ura-prog--fill' : null,
  tier === 'blur' ? 'ura-prog--blur' : null,
  tier === 'fade' ? 'ura-prog--fade' : null,
  className,
]
  .filter(Boolean)
  .join(' ');

const imgClassFull = [isProgressive ? 'ura-prog__img' : null, imgClass]
  .filter(Boolean)
  .join(' ');

const wrapperStyle =
  tier === 'blur' && resolvedLqip
    ? `--ura-lqip: url('${resolvedLqip}')`
    : undefined;
---

{
  src && (
    <picture
      class={wrapperClass}
      data-progressive={isProgressive || undefined}
      style={wrapperStyle}
    >
      {resolvedSources.map((s) => (
        <source media={s.media} srcset={s.srcset} sizes={resolvedSizes} />
      ))}
      <img
        src={displaySrc}
        srcset={srcset || undefined}
        alt={alt}
        class={imgClassFull}
        data-progressive-img={isProgressive || undefined}
        loading={loading}
        fetchpriority={fetchpriority}
        decoding={decoding}
        width={width}
        height={height}
        sizes={resolvedSizes}
        style={objectPosition ? `object-position:${objectPosition}` : undefined}
      />
    </picture>
  )
}
