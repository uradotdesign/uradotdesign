---
import { getLocalizedField, type Language } from '../../lib/i18n';

interface Props {
  data: Record<string, any>;
  lang: Language;
}

const { data, lang } = Astro.props;
const title = getLocalizedField(data, 'title', lang);
const html = (data.html as string) || '';

const aspectMap: Record<string, string> = {
  '16:9': 'aspect-[16/9]',
  '4:3': 'aspect-[4/3]',
  '1:1': 'aspect-square',
  auto: '',
};
const aspectClass = aspectMap[data.aspect as string] ?? aspectMap['16:9'];
---

{
  html && (
    <section class="py-12 md:py-20">
      <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-12 xl:px-16">
        {title && (
          <h2 class="font-display text-2xl sm:text-3xl tracking-[-0.02em] mb-6">
            {title}
          </h2>
        )}
        <div
          class={`block-embed overflow-hidden rounded-2xl ${aspectClass}`}
          set:html={html}
        />
      </div>
    </section>
  )
}

<style>
  .block-embed :global(iframe),
  .block-embed :global(video),
  .block-embed :global(embed) {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
