---
import { getLocalizedField, type Language } from '../../lib/i18n';

interface Props {
  data: Record<string, any>;
  lang: Language;
}

const { data, lang } = Astro.props;
const heading = getLocalizedField(data, 'heading', lang);

const rawItems: any[] = Array.isArray(data.items) ? data.items : [];
const items = rawItems
  .map((it) => ({
    value: it?.value,
    label: getLocalizedField(it, 'label', lang),
  }))
  .filter((it) => it.value || it.label);

const colMap: Record<number, string> = {
  1: 'sm:grid-cols-1',
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
};
const cols = colMap[Math.min(items.length, 4) as 1 | 2 | 3 | 4] || colMap[3];
---

{
  items.length > 0 && (
    <section class="py-12 md:py-20">
      <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-12 xl:px-16">
        {heading && (
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl tracking-[-0.02em] mb-12 text-center">
            {heading}
          </h2>
        )}
        <div class={`grid grid-cols-1 ${cols} gap-8 md:gap-12`}>
          {items.map((it) => (
            <div class="text-center">
              <div class="font-display text-5xl sm:text-6xl lg:text-7xl tracking-[-0.03em]">
                {it.value}
              </div>
              {it.label && (
                <div class="mt-3 text-base md:text-lg font-serif opacity-70">
                  {it.label}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
