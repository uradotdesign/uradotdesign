---
import { getLocalizedField, type Language } from '../../lib/i18n';

interface Props {
  data: Record<string, any>;
  lang: Language;
}

const { data, lang } = Astro.props;
const heading = getLocalizedField(data, 'heading', lang);

const rawItems: any[] = Array.isArray(data.items) ? data.items : [];
const items = rawItems
  .map((it) => ({
    question: getLocalizedField(it, 'question', lang),
    answer: getLocalizedField(it, 'answer', lang),
  }))
  .filter((it) => it.question);
---

{
  items.length > 0 && (
    <section class="py-16 lg:py-24">
      <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-12 xl:px-16">
        {heading && (
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl tracking-[-0.02em] mb-10">
            {heading}
          </h2>
        )}
        <div class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
          {items.map((it) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer items-center justify-between gap-4 list-none text-lg md:text-xl font-medium">
                <span>{it.question}</span>
                <svg
                  class="w-5 h-5 shrink-0 transition-transform duration-200 group-open:rotate-45"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </summary>
              {it.answer && (
                <div class="mt-3 text-base md:text-lg font-serif opacity-80 leading-relaxed">
                  {it.answer}
                </div>
              )}
            </details>
          ))}
        </div>
      </div>
    </section>
  )
}
