---
import { getAssetUrl } from '../../lib/directus';
import { getLocalizedField, type Language } from '../../lib/i18n';
import ProgressiveImage from '../ProgressiveImage.astro';

interface Props {
  data: Record<string, any>;
  lang: Language;
}

const { data, lang } = Astro.props;
const quote = getLocalizedField(data, 'quote', lang);
const role = getLocalizedField(data, 'role', lang);
const author = data.author as string | undefined;
const photo = getAssetUrl(data.photo);
---

{
  quote && (
    <section class="py-12 md:py-20">
      <div class="mx-auto max-w-4xl px-6 sm:px-8 lg:px-12 xl:px-16 text-center">
        <blockquote class="font-display text-2xl sm:text-3xl lg:text-4xl leading-snug tracking-[-0.01em]">
          <span aria-hidden="true" class="opacity-40">“</span>
          {quote}
          <span aria-hidden="true" class="opacity-40">”</span>
        </blockquote>
        {(author || photo) && (
          <figcaption class="mt-8 flex items-center justify-center gap-4">
            {photo && (
              <ProgressiveImage
                src={photo}
                alt={author || ''}
                class="w-12 h-12 rounded-full overflow-hidden shrink-0"
                imgClass="w-full h-full object-cover"
              />
            )}
            <div class="text-left">
              {author && <div class="font-medium">{author}</div>}
              {role && <div class="text-sm opacity-70 font-serif">{role}</div>}
            </div>
          </figcaption>
        )}
      </div>
    </section>
  )
}
