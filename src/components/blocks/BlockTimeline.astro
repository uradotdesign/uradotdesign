---
import { getLocalizedField, type Language } from '../../lib/i18n';

interface Props {
  data: Record<string, any>;
  lang: Language;
}

const { data, lang } = Astro.props;
const heading = getLocalizedField(data, 'heading', lang);

const rawItems: any[] = Array.isArray(data.items) ? data.items : [];
const items = rawItems
  .map((it) => ({
    icon: (it?.icon as string | undefined)?.trim() || '',
    title: getLocalizedField(it, 'title', lang),
    body: getLocalizedField(it, 'body', lang),
  }))
  .filter((it) => it.title);
---

{
  items.length > 0 && (
    <section class="py-16 lg:py-24">
      <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-12 xl:px-16">
        {heading && (
          <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl tracking-[-0.02em] mb-12">
            {heading}
          </h2>
        )}
        <ol class="relative border-l border-[var(--color-border)] ml-3">
          {items.map((it) => (
            <li class="relative pl-8 pb-10 last:pb-0">
              <span class="absolute -left-[9px] top-1 flex h-4 w-4 items-center justify-center rounded-full bg-[var(--color-foreground)] text-[10px] text-[var(--color-background)] ring-4 ring-[var(--color-background)]">
                {it.icon}
              </span>
              <h3 class="font-display text-xl md:text-2xl tracking-[-0.01em]">
                {it.title}
              </h3>
              {it.body && (
                <div
                  class="mt-2 text-base md:text-lg font-serif opacity-80 leading-relaxed [&_a]:underline [&_p]:mt-3 first:[&_p]:mt-0"
                  set:html={it.body}
                />
              )}
            </li>
          ))}
        </ol>
      </div>
    </section>
  )
}
