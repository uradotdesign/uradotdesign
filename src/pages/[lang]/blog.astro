---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPosts, getAssetUrl, getAssetThumbUrl } from "../../lib/directus";
import { getLocalizedField, type Language } from "../../lib/i18n";
import ProgressiveImage from "../../components/ProgressiveImage.astro";

export const prerender = false;

const lang = (Astro.params.lang as Language) || "en";
const supportedLanguages: Language[] = ["en", "de"];
if (!supportedLanguages.includes(lang)) {
  return Astro.rewrite("/404");
}

const copy = {
  en: {
    eyebrow: "Journal",
    title: "Blog",
    description: "Insights and updates from the Ura Design team",
    intro:
      "Insights and updates from our team on design, open source, and building better digital experiences.",
    readArticle: "Read Article",
    allArticles: "All Articles",
    postsLabel: "posts",
    emptyTitle: "No posts yet",
    emptyBody:
      "Check back soon for new content. We're working on some great articles.",
    minReadLong: "min read",
    minReadShort: "min read",
    dateLocale: "en-US",
  },
  de: {
    eyebrow: "Journal",
    title: "Blog",
    description: "Einblicke, Tutorials und Updates vom Ura Design Team",
    intro:
      "Einblicke, Tutorials und Updates von unserem Team zu Design, Open Source und besseren digitalen Erlebnissen.",
    readArticle: "Artikel lesen",
    allArticles: "Alle Artikel",
    postsLabel: "Beiträge",
    emptyTitle: "Noch keine Beiträge",
    emptyBody: "Schau bald wieder vorbei. Wir arbeiten an tollen Artikeln.",
    minReadLong: "Min. Lesezeit",
    minReadShort: "Min.",
    dateLocale: "de-DE",
  },
}[lang];

const rawArticles = await getBlogPosts({
  filter: { status: { _eq: "published" } },
  sort: ["-published_date"],
  fields: ["id", "title", "slug", "excerpt", "content", "cover_image", "published_date", "badge", "author.full_name", "author.photo", "translations.*"],
});

const articles = rawArticles.map((a) => ({
  ...a,
  title: getLocalizedField(a, "title", lang) || a.title,
  excerpt: getLocalizedField(a, "excerpt", lang) || a.excerpt,
  content: getLocalizedField(a, "content", lang) || a.content,
}));

function calculateReadingTime(text: string): number {
  if (!text) return 0;
  const wordsPerMinute = 200;
  const words = text.trim().split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
}

// Get featured article (first one)
const featuredArticle = articles[0];
const remainingArticles = articles.slice(1);
---

<BaseLayout title={copy.title} description={copy.description}>
  {/* Hero Section */}
  <section
    class="relative flex items-end bg-[var(--color-background)] text-[var(--color-foreground)]"
  >
    <div
      class="w-full max-w-[1440px] mx-auto px-6 sm:px-8 lg:px-12 xl:px-16 py-24 lg:py-32"
    >
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-end">
        {/* Left: Title */}
        <div>
          <span
            class="block text-xs uppercase font-mono font-medium tracking-wider opacity-60 mb-6"
          >
            {copy.eyebrow}
          </span>
          <h1
            class="font-display text-6xl sm:text-7xl lg:text-8xl xl:text-9xl leading-[0.9]"
          >
            {copy.title}
          </h1>
        </div>

        {/* Right: Description */}
        <div class="lg:pb-4">
          <p class="text-xl lg:text-2xl opacity-80 max-w-lg">
            {copy.intro}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Featured Article */}
  {
    featuredArticle && (
      <section class="bg-[var(--color-background)] text-[var(--color-foreground)] border-t border-[var(--color-border)]">
        <div class="max-w-[1440px] mx-auto">
          <a
            href={`/${lang}/blog/${featuredArticle.slug}`}
            class="group grid grid-cols-1 lg:grid-cols-2 min-h-[60vh]"
          >
            {/* Image */}
            <div class="relative aspect-[4/3] lg:aspect-auto overflow-hidden bg-gray-100 dark:bg-gray-900">
              {featuredArticle.cover_image ? (
                <ProgressiveImage
                  src={getAssetUrl(featuredArticle.cover_image)}
                  lqip={getAssetThumbUrl(getAssetUrl(featuredArticle.cover_image))}
                  placeholder="blur"
                  fill
                  alt=""
                  imgClass="transition-transform duration-700 group-hover:scale-105"
                  sizes="(max-width: 1024px) 100vw, 50vw"
                  loading="eager"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-900" />
              )}
            </div>

            {/* Content */}
            <div class="flex flex-col justify-between p-8 lg:p-12 xl:p-16">
              <div>
                <div class="flex items-center gap-4 mb-8">
                  {featuredArticle.badge && (
                    <span class="bg-[var(--color-foreground)] text-[var(--color-background)] px-3 py-1 text-xs font-medium uppercase tracking-wider">
                      {featuredArticle.badge}
                    </span>
                  )}
                  <span class="text-sm font-mono opacity-60">
                    {calculateReadingTime(featuredArticle.content || "")}{" "}
                    {copy.minReadLong}
                  </span>
                </div>

                <h2 class="font-display text-4xl sm:text-5xl lg:text-6xl mb-6 leading-tight">
                  {featuredArticle.title}
                </h2>

                {featuredArticle.excerpt && (
                  <p class="text-lg opacity-80 max-w-xl font-serif leading-relaxed">
                    {featuredArticle.excerpt}
                  </p>
                )}
              </div>

              <div class="flex items-center justify-between pt-8 mt-8 border-t border-[var(--color-border)]">
                <div class="flex items-center gap-4">
                  {featuredArticle.author &&
                    typeof featuredArticle.author === "object" && (
                      <>
                        {featuredArticle.author.photo && (
                          <img
                            src={
                              getAssetUrl(featuredArticle.author.photo) || ""
                            }
                            alt={featuredArticle.author.full_name}
                            class="w-10 h-10 rounded-full object-cover grayscale"
                          />
                        )}
                        <span class="text-sm font-medium">
                          {featuredArticle.author.full_name}
                        </span>
                      </>
                    )}
                </div>

                <div class="flex items-center gap-2 text-sm font-medium">
                  <span>{copy.readArticle}</span>
                  <svg
                    class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"
                    />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </div>
      </section>
    )
  }

  {/* Articles Grid */}
  <section
    class="py-16 lg:py-24 bg-[var(--color-background)] text-[var(--color-foreground)]"
  >
    <div class="max-w-[1440px] mx-auto px-6 sm:px-8 lg:px-12 xl:px-16">
      {/* Section Header */}
      <div class="flex items-center gap-6 mb-12">
        <h2 class="uppercase text-xs font-semibold tracking-wider">
          {copy.allArticles}
        </h2>
        <div class="flex-1 h-px bg-[var(--color-border)]" aria-hidden="true">
        </div>
        <span class="text-xs font-mono opacity-60"
          >{articles.length} {copy.postsLabel}</span
        >
      </div>

      {
        articles.length === 0 ? (
          <div class="text-center py-24 border border-[var(--color-border)] rounded-2xl">
            <h3 class="font-display text-3xl mb-4">{copy.emptyTitle}</h3>
            <p class="opacity-60 max-w-md mx-auto">{copy.emptyBody}</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
            {remainingArticles.map((article) => (
              <article class="post-card flex flex-col">
                {/* Image */}
                <a
                  href={`/${lang}/blog/${article.slug}`}
                  class="relative aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-gray-900 mb-6"
                >
                  {article.cover_image ? (
                    <ProgressiveImage
                      src={getAssetUrl(article.cover_image)}
                      lqip={getAssetThumbUrl(getAssetUrl(article.cover_image))}
                      placeholder="blur"
                      fill
                      alt=""
                      imgClass="post-card-img"
                      sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 dark:from-gray-800 dark:to-gray-900" />
                  )}
                </a>

                {/* Content */}
                <div class="flex flex-col flex-1">
                  <div class="flex items-center gap-3 mb-4">
                    {article.badge && (
                      <span class="text-xs font-mono uppercase tracking-wider opacity-60">
                        {article.badge}
                      </span>
                    )}
                    {article.badge && article.published_date && (
                      <span class="w-1 h-1 rounded-full bg-current opacity-30" />
                    )}
                    {article.published_date && (
                      <time class="text-xs font-mono opacity-60">
                        {new Date(article.published_date).toLocaleDateString(
                          copy.dateLocale,
                          {
                            month: "short",
                            day: "numeric",
                            year: "numeric",
                          }
                        )}
                      </time>
                    )}
                  </div>

                  <h3 class="font-display text-2xl lg:text-3xl mb-3 leading-tight">
                    <a
                      href={`/${lang}/blog/${article.slug}`}
                      class="post-card-title"
                    >
                      {article.title}
                    </a>
                  </h3>

                  {article.excerpt && (
                    <p class="text-sm opacity-70 line-clamp-2 mb-4 flex-1">
                      {article.excerpt}
                    </p>
                  )}

                  <div class="flex items-center justify-between pt-4 mt-auto border-t border-[var(--color-border)]/40">
                    {article.author && typeof article.author === "object" ? (
                      <span class="text-xs font-medium opacity-70">
                        {article.author.full_name}
                      </span>
                    ) : (
                      <span />
                    )}
                    <span class="text-xs font-mono opacity-60">
                      {calculateReadingTime(article.content || "")}{" "}
                      {copy.minReadShort}
                    </span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Blog grid card hover: a smooth cover zoom + a title underline that grows
     in — no lift, no shadow. */

  /* The cover <img> is rendered by the ProgressiveImage child component, so its
     classes are outside this page's style scope, and the progressive-reveal
     rule in globals.css (@layer components) otherwise overrides Tailwind's
     transition utilities — which made the zoom snap instantly. Defining the
     zoom here, as an UNLAYERED :global() rule, reliably wins the cascade over
     every @layer. We keep the reveal's opacity transition and add transform. */
  .post-card :global(.post-card-img) {
    transition: opacity 0.35s ease,
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .post-card:hover :global(.post-card-img) {
    transform: scale(1.05);
  }

  /* Title underline grows in from the left on hover (and on keyboard focus),
     instead of an instant text-decoration. */
  .post-card-title {
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 1px;
    padding-bottom: 2px;
    transition: background-size 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .post-card:hover .post-card-title,
  .post-card-title:focus-visible {
    background-size: 100% 1px;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card :global(.post-card-img) {
      transition: none;
    }
    .post-card:hover :global(.post-card-img) {
      transform: none;
    }
    .post-card-title {
      transition: none;
    }
  }
</style>
