---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getCaseStudies,
  getAssetUrl,
  getAssetMeta,
  isPreviewActive,
  getPreviewItemBySlug,
  PAGE_BLOCK_FIELDS,
  sortBlocks,
  type CaseStudy,
} from "../../../lib/directus";
import { getLocalizedField, type Language } from "../../../lib/i18n";
import { getUI } from "../../../lib/translations";
import ThemeResponsiveImage from "../../../components/ThemeResponsiveImage.astro";
import PageBlocks from "../../../components/blocks/PageBlocks.astro";

const { lang: langParam, slug } = Astro.params;
const lang = (langParam as Language) || "en";

const supportedLanguages: Language[] = ["en", "de"];
if (!supportedLanguages.includes(lang)) {
  return Astro.rewrite("/404");
}

if (!slug) {
  return Astro.rewrite("/404");
}

const CASE_STUDY_FIELDS = [
  "slug",
  "status",
  "id",
  "client_name",
  "year",
  "links",
  "categories.category_id.translations.*",
  "featured_image_light",
  "featured_image_dark",
  "featured_image_mobile_light",
  "featured_image_mobile_dark",
  "cover_image",
  "logo",
  "seo_image",
  "translations.*",
  "sections.*", // Fetch all section fields
  "sections.translations.*",
  "sections.images.*",
  "sections.images.translations.*",
  // Additive page-builder blocks (rendered after the sections).
  ...PAGE_BLOCK_FIELDS,
];

// Live Preview: draft-aware, cache-bypassing fetch when ?preview=<secret>.
const isPreview = isPreviewActive(Astro.url);

let study: CaseStudy | null;
if (isPreview) {
  study = await getPreviewItemBySlug<CaseStudy>(
    "case_studies",
    slug,
    CASE_STUDY_FIELDS
  );
  if (study?.sections) {
    study.sections.sort(
      (a: any, b: any) => (a.sort || 0) - (b.sort || 0)
    );
  }
} else {
  const caseStudies = await getCaseStudies({
    fields: CASE_STUDY_FIELDS,
    filter: {
      slug: { _eq: slug },
      status: { _eq: "published" },
    },
    limit: 1,
  });
  study = caseStudies[0] ?? null;
}

// Redirect to 404 if study is not found
if (!study) {
  console.error(`Study not found for slug: ${slug} and lang: ${lang}`);
  return Astro.rewrite("/404");
}

// Additive page-builder blocks (sorted; never replaces the sections above).
const caseStudyBlocks = sortBlocks(study.blocks);

// Normalize data
const title = getLocalizedField(study, "title", lang);
const description =
  getLocalizedField(study, "description", lang) ||
  getLocalizedField(study, "excerpt", lang);
const clientName = study.client_name;
const year = study.year;
const links = study.links || [];
const imageLight = getAssetUrl(study.featured_image_light);
const imageDark = getAssetUrl(study.featured_image_dark);
const coverImage = getAssetUrl(study.cover_image);
const logo = getAssetUrl(study.logo);

// Cover image keeps existing precedence as the single-image fallback.
const heroImageLight = coverImage || imageLight;
const heroImageDark = coverImage || imageDark;
const heroImageMobileLight = getAssetUrl(study.featured_image_mobile_light);
const heroImageMobileDark = getAssetUrl(study.featured_image_mobile_dark);

// Optional SEO overrides (fall back to the page's own title/description/image).
const seoImage = getAssetUrl(study.seo_image);
const metaTitle = getLocalizedField(study, "seo_title", lang) || title;
const metaDescription =
  getLocalizedField(study, "seo_description", lang) || description;

// Hero alt text + focal point (from the file metadata of the shown image).
const heroFileId = study.cover_image || study.featured_image_light;
const heroMeta = await getAssetMeta(heroFileId);
const heroFocal = heroMeta
  ? `${heroMeta.focalX}% ${heroMeta.focalY}%`
  : undefined;

const categories =
  study.categories
    ?.map((catLink: any) => {
      const cat = catLink.category_id;
      const localizedTitle = getLocalizedField(cat, "title", lang);
      return localizedTitle;
    })
    .filter((cat: string | undefined): cat is string => Boolean(cat)) || [];

const sectionImagesByColumn = (section: any, column: number) =>
  (Array.isArray(section?.images) ? section.images : [])
    .filter((img: any) => Number(img?.column) === column)
    .sort((a: any, b: any) => (a?.sort ?? 0) - (b?.sort ?? 0));

// Breadcrumb text
const ui = await getUI(lang);
const worksLink = `/${lang}/works`;

// Structured data: case study (CreativeWork) + breadcrumb trail.
const workUrl = new URL(`/${lang}/work/${slug}`, Astro.site).href;
const workImage = seoImage || coverImage || imageLight;
const caseStudyJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: title,
  ...(metaDescription ? { description: metaDescription } : {}),
  ...(workImage ? { image: [workImage] } : {}),
  ...(clientName ? { creator: { "@type": "Organization", name: clientName } } : {}),
  ...((study as any).date_updated
    ? { dateModified: new Date((study as any).date_updated).toISOString() }
    : {}),
  url: workUrl,
  inLanguage: lang,
};
const workBreadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Work",
      item: new URL(worksLink, Astro.site).href,
    },
    { "@type": "ListItem", position: 2, name: title, item: workUrl },
  ],
};
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  image={seoImage || coverImage || imageLight || undefined}
  jsonLd={[caseStudyJsonLd, workBreadcrumbJsonLd]}
>
  {
    isPreview && (
      <div class="fixed bottom-4 left-1/2 -translate-x-1/2 z-[9999] bg-[#FD5825] text-white text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded-full shadow-lg pointer-events-none">
        {ui("preview.draft")}
      </div>
    )
  }
  <!-- Hero Section -->
  <section
    class="relative w-full min-h-screen flex flex-col justify-between px-6 sm:px-8 lg:px-12 xl:px-24 pt-20 pb-16 sm:py-32 text-white overflow-hidden"
  >
    {/* Background Images */}
    <div class="absolute inset-0 -z-10">
      <ThemeResponsiveImage
        light={heroImageLight}
        dark={heroImageDark}
        mobileLight={heroImageMobileLight}
        mobileDark={heroImageMobileDark}
        alt={heroMeta?.alt || ""}
        objectPosition={heroFocal}
        imgClass="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        placeholder="blur"
        fill
      />
      {
        /* Overlay Gradients - minimal overlay for text legibility, no heavy white/black gradient */
      }
      <div class="absolute inset-0 bg-black/40 dark:bg-black/40"></div>
    </div>

    {/* Top Row */}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 w-full pt-12">
      {/* Top Left: Breadcrumb & Title */}
      <div class="flex flex-col gap-8 max-w-3xl">
        <div>
          <span class="block text-sm uppercase mb-4 opacity-70">
            <a
              href={worksLink}
              class="hover:opacity-100 underline font-semibold transition-opacity"
              >{ui("work.breadcrumb")}</a
            >
            <span>{" "} /</span>
          </span>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl xl:text-8xl">
            {title}
          </h1>
        </div>
      </div>

      {/* Top Right: Description */}
      <div class="flex flex-col justify-end lg:items-end lg:text-right">
        <p
          class="text-xl sm:text-2xl lg:text-3xl font-light max-w-2xl opacity-90"
        >
          {description}
        </p>
      </div>
    </div>

    {/* Bottom Row */}
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-12 w-full items-end mt-auto pt-24"
    >
      {/* Bottom Left: Logo */}
      <div>
        {
          logo && (
            <img
              src={logo}
              alt={ui("work.logoAlt", { name: clientName })}
              class="h-14 w-auto object-contain brightness-0 invert opacity-90"
            />
          )
        }
      </div>

      {/* Bottom Right: Meta Info */}
      <div class="flex flex-col lg:items-end gap-8 lg:text-right">
        {/* Year */}
        {
          year && (
            <div class="flex flex-col gap-2">
              <span class="text-sm uppercase opacity-50">{ui("work.year")}</span>
              <span class="text-lg font-medium">{year}</span>
            </div>
          )
        }

        {/* Links */}
        {
          links.length > 0 && (
            <div class="flex flex-col gap-2 lg:items-end">
              <span class="text-sm uppercase opacity-50">
                {ui("work.links")}
              </span>
              <div class="flex flex-col gap-3 lg:gap-1 lg:items-end">
                {links.map((link: any) => (
                  <div class="w-fit">
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="hero-link text-lg font-medium border-b border-white pb-0.5 hover:opacity-70 transition-opacity block w-fit"
                    >
                      {getLocalizedField(link, "label", lang) || link.label}
                    </a>
                  </div>
                ))}
              </div>
            </div>
          )
        }

        {/* Categories */}
        {
          categories.length > 0 && (
            <div class="flex flex-col gap-2 lg:items-end">
              <div class="flex flex-wrap gap-2 lg:justify-end">
                {categories.map((cat: string) => (
                  <span class="text-sm font-medium text-white/90">{cat}</span>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>

  {/* Dynamic Sections */}
  {
    study.sections && study.sections.length > 0
      ? study.sections.map((section: any) => {
          const colImages = [1, 2, 3].map((c) => sectionImagesByColumn(section, c));
          return (
            <section class="py-8 lg:py-20 px-6 sm:px-8 lg:px-12 xl:px-24 w-full mx-auto">
              <div class="flex flex-col lg:flex-row gap-6 lg:gap-24">
                {/* Left: Section Title */}
                <div class="lg:w-1/6 lg:sticky lg:top-32 h-fit">
                  <h2 class="text-lg font-mono opacity-80 font-medium">
                    {getLocalizedField(section, "title", lang) || section.title}
                  </h2>
                </div>

                {/* Right: Content Grid */}
                <div
                  class={`lg:w-5/6 grid sm:gap-32 gap-4 ${
                    section.layout === "3-cols"
                      ? "lg:grid-cols-3"
                      : section.layout === "2-cols"
                        ? "lg:grid-cols-2"
                        : "grid-cols-1"
                  }`}
                >
                  {[1, 2, 3].map((col) => {
                    const content =
                      getLocalizedField(section, `content_${col}`, lang) ||
                      section[`content_${col}`];
                    const customCode = section[`custom_code_${col}`];
                    const images = colImages[col - 1];
                    if (!content && !customCode && images.length === 0) return null;
                    return (
                      <div class="flex flex-col gap-8">
                        {content && (
                          <div
                            class="prose dark:prose-invert max-w-none prose-p:text-lg prose-p:leading-relaxed prose-headings:font-display prose-img:my-0 w-full"
                            set:html={content}
                          />
                        )}
                        {images.map((img: any) => (
                          <ThemeResponsiveImage
                            light={getAssetUrl(img.image_light)}
                            dark={getAssetUrl(img.image_dark)}
                            mobileLight={getAssetUrl(img.image_mobile_light)}
                            mobileDark={getAssetUrl(img.image_mobile_dark)}
                            alt={getLocalizedField(img, "alt", lang) || img.alt || ""}
                            class="block w-full"
                            imgClass="w-full h-auto rounded-lg"
                            sizes="(max-width: 1024px) 100vw, 50vw"
                          />
                        ))}
                        {/* custom_code is trusted admin-authored HTML/CSS/JS from Directus */}
                        {customCode && <div class="w-full" set:html={customCode} />}
                      </div>
                    );
                  })}
                </div>
              </div>
            </section>
          );
        })
      : null
  }

  {/* Additive page-builder blocks (after the case study sections) */}
  {caseStudyBlocks.length > 0 && <PageBlocks blocks={caseStudyBlocks} lang={lang} />}

  <!-- Inject the custom element script for Before/After toggle -->
  <script>
    import "../../../scripts/BeforeAfterToggle.js";
    import "../../../scripts/InteractiveShowcase.js";
    import "../../../scripts/CharacterSystem.js";
    import "../../../scripts/LottiePlayerGrid.js";
  </script>
</BaseLayout>

<style>
  /* Force white header on desktop for this page to match dark hero background,
     BUT only when the header is transparent (not scrolled).
     When scrolled, it should behave normally (adaptive).
  */
  @media (min-width: 768px) {
    :global(header:not(.scrolled) .adaptive-color),
    :global(header:not(.scrolled) .nav-link) {
      color: #ffffff !important;
    }

    /* The "Let's talk" CTA hover turns its background solid white in light
       theme, so the forced-white header text above leaves it white-on-white.
       Force dark text on hover for contrast; in dark theme the hero stays dark
       (translucent hover), so keep the CTA text white. */
    :global(header:not(.scrolled) .header-cta-button:hover) {
      color: #111827 !important;
    }
    :global(.dark header:not(.scrolled) .header-cta-button:hover) {
      color: #ffffff !important;
    }

    :global(header:not(.scrolled) .logo-path) {
      fill: #ffffff !important;
    }

    :global(header:not(.scrolled) .header-divider) {
      background-color: #ffffff !important;
    }

    /* Force white underline for links in hero section */
    .hero-link {
      border-bottom-color: #ffffff !important;
    }

    /* Force weather text and icons to white */
    :global(header:not(.scrolled) [role="status"]),
    :global(header:not(.scrolled) [role="status"] span),
    :global(header:not(.scrolled) [role="status"] svg),
    :global(header:not(.scrolled) time) {
      color: #ffffff !important;
    }
  }
</style>
