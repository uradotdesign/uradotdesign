---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCurrentLanguage } from '../lib/i18n';

const currentLang = getCurrentLanguage(Astro.url);

const messages = {
  en: {
    title: 'Something went wrong',
    heading: '500',
    subheading: 'Something went wrong',
    description:
      'An unexpected error occurred on our end. Please try again in a moment.',
    cta: 'Back to Home',
    home: '/en',
  },
  de: {
    title: 'Etwas ist schiefgelaufen',
    heading: '500',
    subheading: 'Etwas ist schiefgelaufen',
    description:
      'Auf unserer Seite ist ein unerwarteter Fehler aufgetreten. Bitte versuche es gleich noch einmal.',
    cta: 'Zur Startseite',
    home: '/de',
  },
};

const msg = messages[currentLang] || messages.en;

Astro.response.status = 500;
---

<BaseLayout title={msg.title} noindex>
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-6 text-center">
    <h1 class="text-8xl sm:text-9xl font-bold tracking-tight text-[var(--color-foreground)] opacity-20 select-none">
      {msg.heading}
    </h1>
    <h2 class="text-2xl sm:text-3xl font-medium mt-4 text-[var(--color-foreground)]">
      {msg.subheading}
    </h2>
    <p class="text-lg text-[var(--color-muted-foreground)] mt-4 max-w-md">
      {msg.description}
    </p>
    <a
      href={msg.home}
      class="mt-8 inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--color-foreground)] text-[var(--color-background)] font-medium transition-opacity hover:opacity-80"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      {msg.cta}
    </a>
  </section>
</BaseLayout>
