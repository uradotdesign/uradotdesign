# Public URL for the browser (Client-side)
# In production, this should be your public domain (e.g., https://cms.yourdomain.com)
PUBLIC_DIRECTUS_URL=http://localhost:8055

# Internal URL for the server (Server-side SSR)
# In Docker, this is usually http://directus:8055
DIRECTUS_URL=http://localhost:8055

# Site URL
# In production, this is your main domain (e.g. https://yourdomain.com)
PUBLIC_URL=http://localhost:3000

# Directus Settings
# MUST CHANGE: generate strong random values, e.g. `openssl rand -hex 32`
KEY=replace-with-random-secret
SECRET=replace-with-random-secret
ADMIN_EMAIL=admin@ura.design
# MUST CHANGE: use a strong, unique password (no default is provided)
ADMIN_PASSWORD=change-me-strong-password

# Database Settings
POSTGRES_USER=directus
# MUST CHANGE in any non-local environment
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=directus

# Redis Settings (Application)
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: set to enable Redis auth (--requirepass). When set, also update
# REDIS_URL below to redis://:<password>@redis:6379 for Directus.
# REDIS_PASSWORD=
# Redis URL for Directus
CACHE_ENABLED=true
CACHE_STORE=redis
REDIS_URL=redis://redis:6379

# Weather API (OpenWeatherMap)
OPENWEATHER_API_KEY=your-api-key-here
WEATHER_LOCATION=Berlin
WEATHER_CACHE_TTL=900

# i18n
DEFAULT_LOCALE=en
AVAILABLE_LOCALES=en,de

# Email / SMTP (for Directus Flow notifications)
# EMAIL_FROM is the sender address shown in outgoing emails
EMAIL_FROM=noreply@ura.design
# EMAIL_TRANSPORT: smtp | sendmail | ses
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASSWORD=your-smtp-password
# EMAIL_SMTP_SECURE: true for port 465 (SSL), false for 587 (STARTTLS)
EMAIL_SMTP_SECURE=false
# Validate SMTP TLS certs by default. Set to false ONLY for providers whose
# cert chain requires it (e.g. ProtonMail direct SMTP).
EMAIL_SMTP_TLS_REJECT_UNAUTHORIZED=true

# Helper variables for scripts
DIRECTUS_CONFIG_CACHE=true
DIRECTUS_CONFIG_CACHE_TTL=3600
